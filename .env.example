# Copy to .env.local for local dev. Next.js auto-loads .env.local and
# git-ignores it. For production, set the same vars in Vercel's env UI.
#
# Naming convention: {CHAIN_SLUG_UPPER_SNAKE}_RPC_URL (see env-overrides.ts).
# Server-side only. Do not add NEXT_PUBLIC_ to RPC vars: they may embed API
# keys and must not ship to the client bundle.
#
# A missing RPC URL for an enabled chain throws at first request with a
# message naming the missing var. Disabled chains are not checked.

# ---------------------------------------------------------------------------
# Default network
# ---------------------------------------------------------------------------

# Which network is selected on first visit. Defaults to "mainnet" if unset.
# NEXT_PUBLIC_DEFAULT_NETWORK=mainnet

# ---------------------------------------------------------------------------
# Mainnet RPC URLs
# ---------------------------------------------------------------------------
# Public endpoints for local dev. Swap to paid providers (Validation Cloud,
# Alchemy, Helius, etc.) before production. Public RPCs rate-limit under
# real traffic.

STELLAR_RPC_URL=https://mainnet.sorobanrpc.com
ETHEREUM_RPC_URL=https://eth.llamarpc.com
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
OPTIMISM_RPC_URL=https://mainnet.optimism.io
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
BASE_RPC_URL=https://mainnet.base.org
POLYGON_RPC_URL=https://polygon-rpc.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Arc mainnet is disabled in mainnet.ts until Circle publishes contracts.
# Leave blank until the chain is flipped on.
# ARC_RPC_URL=

# ---------------------------------------------------------------------------
# Testnet RPC URLs (optional)
# ---------------------------------------------------------------------------
# testnet.ts ships with hardcoded public endpoints as fallbacks. Set any of
# the vars below to override (e.g. to use a paid endpoint for higher limits).

# STELLAR_TESTNET_RPC_URL=
# SOLANA_DEVNET_RPC_URL=
# ETHEREUM_SEPOLIA_RPC_URL=
# AVALANCHE_FUJI_RPC_URL=
# OP_SEPOLIA_RPC_URL=
# ARBITRUM_SEPOLIA_RPC_URL=
# BASE_SEPOLIA_RPC_URL=
# POLYGON_AMOY_RPC_URL=
# ARC_TESTNET_RPC_URL=
